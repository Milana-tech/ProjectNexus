# Database
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus
POSTGRES_DB=nexus
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Backend
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# PHP backend (Symfony)
PHP_BACKEND_URL=http://localhost:8001
APP_ENV=dev
APP_DEBUG=1

# Frontend
VITE_API_URL=http://localhost:8000

# Simulator
SIM_ENTITY_NAME=Greenhouse A
SIM_ENTITY_TYPE=greenhouse
SIM_METRICS=temperature,humidity
SIM_INTERVAL_SECONDS=5
SIM_SPIKE_EVERY=20
